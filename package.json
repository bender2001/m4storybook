{
  "name": "@bender2001/m4-components",
  "private": false,
  "version": "0.1.2",
  "type": "module",
  "description": "Material 3 Expressive React component library.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bender2001/m4storybook.git"
  },
  "homepage": "https://github.com/bender2001/m4storybook#readme",
  "bugs": {
    "url": "https://github.com/bender2001/m4storybook/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/components",
    "dist/index.cjs",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/style.css"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib",
    "build:app": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tailwindcss -i ./src/index.css -o ./dist/style.css --minify && tsc -p tsconfig.lib.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:storybook": "test-storybook",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build:lib"
  },
  "dependencies": {
    "motion": "^11.13.1"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/test-runner": "^0.21.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-storybook": "^0.11.1",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.7",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
