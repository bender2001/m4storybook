{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/App.tsx",
    "src/main.tsx",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/foundations/**/*"
  ]
}
